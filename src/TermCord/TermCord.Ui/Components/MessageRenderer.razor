@using System.Diagnostics
@using System.Text.RegularExpressions
@using Discord
@using Discord.Rest
@using Discord.WebSocket
@using TermCord.Services.Interfaces
<div class="d-flex flex-column message-container">
    <div class="d-flex flex-row message-header justify-content-between">
        <div class="message-user">
            @Username
        </div>
        <div class="message-timestamp">
            @Message.Timestamp.ToLocalTime().ToString("HH:mm")
        </div>
    </div>
    <div class="message-body">
        @FormatContent(Message.Content)
    </div>
    <div class="message-images">
        @foreach (var attachment in AttachmentAscii)
        {
            <div class="attachment-image">@attachment</div>
        }
    </div>
</div>

@code {

    [Parameter]
    public required IMessage Message { get; set; }

    [Inject]
    private IDiscordService DiscordService { get; set; } = null!;

    [Inject]
    private IImageService ImageService { get; set; } = null!;

    private List<MarkupString> AttachmentAscii { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        foreach (var attachment in Message.Attachments)
        {
            var ascii = await ImageService.GetAsciiFromImage(attachment.Url);
            AttachmentAscii.Add((MarkupString)ascii);
        }

        await InvokeAsync(StateHasChanged);
    }

    private string Username
    {
        get
        {
            switch (Message.Author)
            {
                case SocketGuildUser guildUser:
                    return guildUser.Nickname;

                case RestGuildUser restGuildUser:
                    return restGuildUser.Nickname;

                default:
                {
                    var guildNick = DiscordService.GetUsername(Message.Author.Id);
                    return guildNick ?? $"@{Message.Author.Username}";
                }
            }
        }
    }

    private string FormatContent(string content)
    {
        content = ReplaceRoleMentions(content);
        return content;
    }

    private string ReplaceRoleMentions(string content)
    {
        var re = new Regex("<@&([0-9]+)>");

        var matches = re.Matches(content);

        foreach (var match in matches)
        {
            var text = match.ToString()!;
            var value = ulong.Parse(text[3..^1]);
            content = content.Replace(text, $"@{DiscordService.GetRoleName(value)}");
        }

        return content;
    }

}